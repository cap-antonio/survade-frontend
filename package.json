{
  "name": "survade-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "generate:api": "npx openapi-typescript http://localhost:8000/api/openapi.v1.yaml -o src/api/generated/schema.d.ts",
    "get:api": "openapi -i http://localhost:8000/api/openapi.v1.yaml -o ./src/api/services/ --name apigen --client axios --useOptions"
  },
  "dependencies": {
    "@lingui/core": "^5.9.2",
    "@lingui/macro": "^5.5.0",
    "@lingui/react": "^5.9.2",
    "@tanstack/react-query": "^5.67.3",
    "@tanstack/react-query-devtools": "^5.67.3",
    "axios": "^1.13.6",
    "babel-plugin-macros": "^3.1.0",
    "classnames": "^2.3.2",
    "next": "15.3.1",
    "openapi-typescript": "^7.6.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@lingui/cli": "^5.3.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "15.3.1",
    "openapi-typescript-codegen": "^0.25.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  }
}
